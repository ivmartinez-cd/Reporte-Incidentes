# ──────────────────────────────────────────────────────────────────────────
#  Canal Directo · Dashboard Ejecutivo de Incidentes — variables de entorno
#  Copiá este archivo a `.env.local` y completá los valores.
#  `.env.local` NUNCA se commitea (está en .gitignore).
# ──────────────────────────────────────────────────────────────────────────

# --- IA (Gemini) -----------------------------------------------------------
# Generá una API key NUEVA en Google AI Studio. (La key que se compartió en el
# chat de desarrollo debe rotarse/revocarse: quedó expuesta en texto plano.)
GEMINI_API_KEY=
# Modelo de clasificación. Default recomendado: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# Precios USD por 1.000.000 de tokens (VERIFICAR contra el tarifario vigente
# de Google antes de presentar costos a la Junta).
GEMINI_PRICE_INPUT_PER_M=0.30
GEMINI_PRICE_OUTPUT_PER_M=2.50

# --- SOAP (Canal Directo wsAyC) -------------------------------------------
SOAP_WSDL_URL=https://wsg.cdsisa.com.ar/wsAyC_server.php?wsdl
SOAP_TIMEOUT_MS=10000
SOAP_MAX_CONCURRENCY=4
SOAP_CACHE_TTL_SECONDS=900
# Si el WSDL requiere login por getUser(Usuario,Password), completá esto.
# (Según pruebas previas el servicio respondía sin credenciales.)
SOAP_USER=
SOAP_PASSWORD=
# Tope de prueba: máximo de incidentes por cliente/mes para no agotar el WSDL.
# Subir (valor alto) o quitar cuando se pase a producción.
SOAP_TEST_INCIDENT_LIMIT=5
# Poné USE_MOCK=true para correr con datos simulados (demo sin tocar el SOAP).
# Poné USE_MOCK=false para consumir el servicio real.
USE_MOCK=true

# --- Auth de la app (login simple) ----------------------------------------
APP_USERNAME=directorio
APP_PASSWORD=cambiar-esta-clave
# Secreto para firmar la cookie de sesión. Generá uno largo y aleatorio:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
